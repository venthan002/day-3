using System;

class Program
{
    static void Main()
    {
        int[] arr1 = { 1, 2, 3 };
        int[] arr2 = { 1, 2, 3 };

        int[] merged = new int[arr1.Length + arr2.Length];

        arr1.CopyTo(merged, 0);
        arr2.CopyTo(merged, arr1.Length);

        Array.Sort(merged);

        Console.WriteLine("Merged Array:");

        foreach (int num in merged)
        {
            Console.Write(num + " ");
        }
    }
}
