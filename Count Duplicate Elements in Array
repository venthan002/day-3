using System;

class Program
{
    static void Main()
    {
        int[] arr = { 5, 1, 1 };

        int count = 0;

        for (int i = 0; i < arr.Length; i++)
        {
            for (int j = i + 1; j < arr.Length; j++)
            {
                if (arr[i] == arr[j])
                {
                    count++;
                    break;
                }
            }
        }

        Console.WriteLine("Total duplicate elements = " + count);
    }
}
