using System;

class Program
{
    static void Main()
    {
        int[] arr = { 13, 433, 49, 420, 4991 };

        Console.WriteLine("Niven Numbers:");

        foreach (int num in arr)
        {
            int temp = num;
            int sum = 0;

            while (temp > 0)
            {
                sum += temp % 10;
                temp /= 10;
            }

            if (num % sum == 0)
            {
                Console.WriteLine(num);
            }
        }
    }
}
